# Convex
CONVEX_DEPLOYMENT=dev:your-deployment-name
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud
APP_URL=http://localhost:3000

# Auth
AUTH_SECRET=replace-with-random-long-secret
ENABLE_ACCOUNT_CLAIM=true
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Resend (email verification + notifications)
# Required in production; without it, signup auto-verifies only in development.
# Get your API key at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxx
# Use a verified sender domain in production, e.g. no-reply@findln.de
RESEND_FROM_EMAIL="findln <no-reply@findln.de>"
